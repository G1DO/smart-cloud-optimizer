# Environment for docker compose. Copy to `.env` (same dir as docker-compose.yml)
# and fill in values:  cp .env.docker.example .env
# All vars are optional — the app ships safe defaults (DEMO_MODE on, no AI key).

# Load the committed synthetic demo data. Set to "false" only for real AWS
# collection (requires valid AWS credentials in the container).
DEMO_MODE=true

# Google Gemini API key for AI architecture recommendations. Empty = AI
# endpoints return an in-band error; the rest of the app works fine.
GOOGLE_API_KEY=

# Gemini model id used by ai_module.
GOOGLE_MODEL=gemini-2.5-flash

# AWS targeting (defaults match the shipped synthetic account).
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=SYNTHETIC-001

# Optional gate for the AI/onboarding endpoints. If set, requests must send a
# matching X-API-Token header. Leave empty to disable the gate.
ONBOARDING_API_TOKEN=

# NOTE: NEXT_PUBLIC_API_BASE_URL is NOT a backend runtime var. It is a frontend
# BUILD arg (set in docker-compose.yml under frontend.build.args) because Next.js
# inlines NEXT_PUBLIC_* values into the browser bundle at build time. It must be
# a host-reachable URL (default http://localhost:8000), not the "backend"
# service name.
